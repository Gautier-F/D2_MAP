Bootstrap: docker
From: rocker/r-ver:4.5

%post
    set -e
    export http_proxy=http://proxy-upgrade.intra.glicid.fr:3128
    export https_proxy=http://proxy-upgrade.intra.glicid.fr:3128

    # Fix sandbox APT
    mkdir -p /etc/apt/apt.conf.d/
    echo 'APT::Sandbox::User "root";' > /etc/apt/apt.conf.d/99sandbox
    echo 'Acquire::http::Proxy "http://proxy-upgrade.intra.glicid.fr:3128";' >> /etc/apt/apt.conf.d/99sandbox
    echo 'Acquire::https::Proxy "http://proxy-upgrade.intra.glicid.fr:3128";' >> /etc/apt/apt.conf.d/99sandbox
    echo 'Acquire::AllowInsecureRepositories "true";' >> /etc/apt/apt.conf.d/99sandbox
    echo 'APT::Get::AllowUnauthenticated "true";' >> /etc/apt/apt.conf.d/99sandbox

    apt-get update -y

    apt-get install -y --no-install-recommends --allow-unauthenticated \
        gnupg2 ubuntu-keyring

    apt-get update -y

    apt-get install -y --no-install-recommends \
        make gcc g++ gfortran \
        libc6-dev \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libgit2-dev \
        pandoc

    # Packages R
    R --slave -e "install.packages('BiocManager', repos='http://cran.r-project.org')"
    R --slave -e "BiocManager::install(ask=FALSE, update=FALSE)"
    R --slave -e "BiocManager::install(
        c('ggplot2',
          'data.table',
          'openxlsx',
          'ggrepel',
          'CMplot',
          'rmarkdown',
          'DT',
          'org.Hs.eg.db',
          'rtracklayer',
          'dplyr',
          'cowplot',
          'stringr'),
        ask=FALSE, update=FALSE, type='source')"

%environment
    export LC_ALL=C
    export http_proxy=http://proxy-upgrade.intra.glicid.fr:3128
    export https_proxy=http://proxy-upgrade.intra.glicid.fr:3128
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

%runscript
    exec R "$@"

%labels
    Author F. Gautier
    Version 1.1
    Description R 4.5 + Bioconductor stack