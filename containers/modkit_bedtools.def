Bootstrap: docker
From: ontresearch/modkit:sha489d708a48c66368e5d1e118538e5dca68203a64

%post
    apt-get update
    apt-get install -y bedtools wget bzip2 build-essential bc
    apt-get install -y \
        zlib1g \
        zlib1g-dev \
        libbz2-1.0 \
        libbz2-dev \
        liblzma5 \
        liblzma-dev \
        libcurl4 \
        libcurl4-openssl-dev \
        libssl-dev \
        pkg-config

    # Installation de htslib (contient bgzip et tabix)
    cd /opt
    wget https://github.com/samtools/htslib/releases/download/1.19/htslib-1.19.tar.bz2
    tar -xjf htslib-1.19.tar.bz2
    cd htslib-1.19
    ./configure --prefix=/usr/local
    make
    make install
